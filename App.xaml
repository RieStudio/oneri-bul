<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="OneriBul.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:OneriBul.Converters"
    xmlns:local="clr-namespace:OneriBul">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!--  Global Converters  -->
            <converters:SelectionToColorConverter
                x:Key="SelectionToColorConverter"
                SelectedColor="#8A2BE2"
                UnselectedColor="#1E1E24" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
